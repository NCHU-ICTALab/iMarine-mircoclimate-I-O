# Central Weather Administration (CWA) Open Data Authorization Key
# Obtain it from: https://opendata.cwa.gov.tw/
CWA_API_KEY=your_cwa_api_key_here

# Database Settings
DATABASE_URL=rain_data.sqlite3

# Server Settings
HOST=127.0.0.1
PORT=8010
DEBUG=True

# Auto-Sync Configuration
AUTO_SYNC_ENABLED=True
AUTO_SYNC_INTERVAL_SECONDS=1800 # 30 minutes

# Target Settings (defaults to Kaohsiung Port area)
# C0V890 (Qianzhen/旗津), C0V490 (Gushan/鼓山), C0V810 (Zuoying/左營), C0V840 (Xiaogang/小港)
# C0V450 (Xiaogang Outer/過港), C0V900 (Linyuan/林園), 467441 (Kaohsiung Station)
TARGET_STATION_IDS=C0V890,C0V490,C0V810,C0V840,C0V450,C0V900,467441
TARGET_FORECAST_LOCATIONS=高雄市
TARGET_LATITUDE=22.62
TARGET_LONGITUDE=120.28

